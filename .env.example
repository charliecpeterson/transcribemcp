# --- LLM endpoint (used by Claude Code, not this MCP server) ---
# Set whichever of these your Claude Code session needs.
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=http://localhost:11434/v1   # optional override (vLLM, Ollama)

# --- Transcription backend selection ---
TRANSCRIPTION_BACKEND=whisperx        # whisperx | qwen3_asr | cohere | stub

# --- WhisperX ---
WHISPER_MODEL=base                    # base|small|medium|large-v3
WHISPERX_DEVICE=auto                  # auto|cpu|cuda|mps
WHISPERX_COMPUTE_TYPE=int8            # int8|float16|float32
WHISPERX_ALIGN=false                  # word-level alignment (slower)

# --- Qwen3-ASR ---
QWEN3_MODE=local                      # local|vllm
QWEN3_SIZE=0.6B                       # 0.6B|1.7B  (local mode only)
QWEN3_VLLM_URL=                       # e.g. https://vllm.internal/v1
QWEN3_VLLM_API_KEY=

# --- Cohere Transcribe ---
# LLM-decoded model (no native timestamps). We preprocess with silero-vad and
# synthesize Segment boundaries from the voiced spans. Install the [vad] +
# [cohere] (or [cohere-mlx] on Apple Silicon) extras.
COHERE_BACKEND=auto                   # auto|transformers|mlx
COHERE_DEVICE=auto                    # auto|cpu|cuda|mps
COHERE_LANG=en                        # English only for now

# --- Diarization (pyannote) ---
# Opt-in: requires HF_TOKEN below + accepted license at
# https://huggingface.co/pyannote/speaker-diarization-community-1
DIARIZE=false
HF_TOKEN=                             # required when DIARIZE=true

# --- Output (optional; blank = write <audio>.transcript.json beside source) ---
# OUTPUT_DIR=~/transcripts
